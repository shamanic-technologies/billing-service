{
  "openapi": "3.0.0",
  "info": {
    "title": "Billing Service API",
    "version": "0.1.0",
    "description": "Manages billing accounts, credit balance, deductions, and Stripe integration for the Conductor platform."
  },
  "servers": [
    {
      "url": "http://localhost:3012"
    }
  ],
  "components": {
    "schemas": {
      "BillingGrowthRow": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string"
          },
          "credited_cents": {
            "type": "string"
          },
          "revenue_cents": {
            "type": "string"
          }
        },
        "required": [
          "period",
          "credited_cents",
          "revenue_cents"
        ]
      },
      "PublicBillingStats": {
        "type": "object",
        "properties": {
          "total_accounts": {
            "type": "integer"
          },
          "accounts_with_payment_method": {
            "type": "integer"
          },
          "total_balance_cents": {
            "type": "string"
          },
          "total_credited_cents": {
            "type": "string"
          },
          "monthly_growth": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillingGrowthRow"
            }
          },
          "weekly_growth": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillingGrowthRow"
            }
          }
        },
        "required": [
          "total_accounts",
          "accounts_with_payment_method",
          "total_balance_cents",
          "total_credited_cents",
          "monthly_growth",
          "weekly_growth"
        ]
      },
      "BillingAccount": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "org_id": {
            "type": "string",
            "format": "uuid"
          },
          "balance_cents": {
            "type": "string"
          },
          "usage_cents": {
            "type": "string"
          },
          "available_cents": {
            "type": "string"
          },
          "topup_amount_cents": {
            "type": "integer",
            "nullable": true
          },
          "topup_threshold_cents": {
            "type": "integer",
            "nullable": true
          },
          "has_payment_method": {
            "type": "boolean"
          },
          "has_auto_topup": {
            "type": "boolean"
          },
          "stripe_customer_id": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "org_id",
          "balance_cents",
          "usage_cents",
          "available_cents",
          "topup_amount_cents",
          "topup_threshold_cents",
          "has_payment_method",
          "has_auto_topup",
          "stripe_customer_id",
          "created_at",
          "updated_at"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "BalanceResponse": {
        "type": "object",
        "properties": {
          "available_cents": {
            "type": "string"
          },
          "depleted": {
            "type": "boolean"
          }
        },
        "required": [
          "available_cents",
          "depleted"
        ]
      },
      "CustomerBalanceTransaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "object": {
            "type": "string",
            "enum": [
              "customer_balance_transaction"
            ]
          },
          "amount_cents": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "payment",
              "gift",
              "promo",
              "refund",
              "usage_applied"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "requires_capture",
              "succeeded",
              "canceled"
            ]
          },
          "stripe_payment_intent_id": {
            "type": "string",
            "nullable": true
          },
          "stripe_balance_transaction_id": {
            "type": "string",
            "nullable": true
          },
          "cost_id": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "created": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "object",
          "amount_cents",
          "type",
          "status",
          "stripe_payment_intent_id",
          "stripe_balance_transaction_id",
          "cost_id",
          "description",
          "created"
        ]
      },
      "CustomerBalanceTransactionList": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "enum": [
              "list"
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomerBalanceTransaction"
            }
          },
          "has_more": {
            "type": "boolean"
          }
        },
        "required": [
          "object",
          "data",
          "has_more"
        ]
      },
      "UpdateAutoTopupRequest": {
        "type": "object",
        "properties": {
          "topup_amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "topup_threshold_cents": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "topup_amount_cents"
        ]
      },
      "PortalSessionResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      },
      "CreatePortalSessionRequest": {
        "type": "object",
        "properties": {
          "return_url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "return_url"
        ]
      },
      "CheckoutResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "session_id"
        ]
      },
      "CreateCheckoutRequest": {
        "type": "object",
        "properties": {
          "success_url": {
            "type": "string",
            "format": "uri"
          },
          "cancel_url": {
            "type": "string",
            "format": "uri"
          },
          "topup_amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          }
        },
        "required": [
          "success_url",
          "cancel_url",
          "topup_amount_cents"
        ]
      },
      "AuthorizeResponse": {
        "type": "object",
        "properties": {
          "sufficient": {
            "type": "boolean"
          },
          "balance_cents": {
            "type": "string"
          },
          "required_cents": {
            "type": "string"
          }
        },
        "required": [
          "sufficient",
          "balance_cents",
          "required_cents"
        ]
      },
      "AuthorizeCostItem": {
        "type": "object",
        "properties": {
          "costName": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          }
        },
        "required": [
          "costName",
          "quantity"
        ]
      },
      "AuthorizeRequest": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorizeCostItem"
            },
            "minItems": 1
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "items"
        ]
      },
      "UsageApplyResponse": {
        "type": "object",
        "properties": {
          "acknowledged": {
            "type": "boolean"
          },
          "topup_triggered": {
            "type": "boolean"
          }
        },
        "required": [
          "acknowledged",
          "topup_triggered"
        ]
      },
      "UsageApplyRequest": {
        "type": "object",
        "properties": {
          "spent_total_cents": {
            "type": "string"
          }
        },
        "required": [
          "spent_total_cents"
        ]
      },
      "RedeemPromotionCodeResponse": {
        "type": "object",
        "properties": {
          "redeemed": {
            "type": "boolean"
          },
          "amount_cents": {
            "type": "string"
          },
          "balance_cents": {
            "type": "string"
          }
        },
        "required": [
          "redeemed",
          "amount_cents",
          "balance_cents"
        ]
      },
      "RedeemPromotionCodeRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "code"
        ]
      },
      "TransferBrandTableResult": {
        "type": "object",
        "properties": {
          "tableName": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        },
        "required": [
          "tableName",
          "count"
        ]
      },
      "TransferBrandResponse": {
        "type": "object",
        "properties": {
          "updatedTables": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransferBrandTableResult"
            }
          }
        },
        "required": [
          "updatedTables"
        ]
      },
      "TransferBrandRequest": {
        "type": "object",
        "properties": {
          "sourceBrandId": {
            "type": "string",
            "format": "uuid"
          },
          "sourceOrgId": {
            "type": "string",
            "format": "uuid"
          },
          "targetOrgId": {
            "type": "string",
            "format": "uuid"
          },
          "targetBrandId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "sourceBrandId",
          "sourceOrgId",
          "targetOrgId"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "service": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "service"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/public/stats/billing": {
      "get": {
        "summary": "Aggregate billing stats (no auth)",
        "description": "Cross-tenant aggregate billing statistics. No authentication required.",
        "responses": {
          "200": {
            "description": "Billing stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicBillingStats"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts": {
      "get": {
        "summary": "Get or create billing account for org",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Billing account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingAccount"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Payment provider authentication failed or runs-service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts/balance": {
      "get": {
        "summary": "Quick available-funds check",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Balance info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                }
              }
            }
          },
          "404": {
            "description": "Billing account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/customer_balance_transactions": {
      "get": {
        "summary": "Paginated customer balance transaction history",
        "description": "Lists the org's customer balance transactions in reverse chronological order. Excludes legacy `usage_applied` rows (frozen post-#104; runs-service owns usage truth). `amount_cents` is SIGNED: negative = credit, positive = debit.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Customer balance transaction list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerBalanceTransactionList"
                }
              }
            }
          },
          "404": {
            "description": "Billing account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts/auto_topup": {
      "patch": {
        "summary": "Configure auto-topup settings (requires payment method)",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAutoTopupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingAccount"
                }
              }
            }
          },
          "400": {
            "description": "Payment method required or invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Billing account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Disable auto-topup",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated account with auto-topup disabled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingAccount"
                }
              }
            }
          },
          "404": {
            "description": "Billing account not found",
