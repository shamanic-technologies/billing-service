    "/v1/credits/authorize": {
      "post": {
        "summary": "Synchronous pre-execution authorization with auto-reload",
        "description": "Auto-creates the billing account with $2.00 trial credit if the org has no account yet. Resolves prices from costs-service, fetches org usage total from runs-service, then checks available credits. Available credits are billing-owned credit grants minus runs-service platform usage total. If insufficient and auto-reload is configured, charges the smallest multiple of reload_amount_cents that covers the required amount (e.g. $10 reload unit, $37 required with $2 balance → charges 4x $10 = $40). Sends email notification on reload failure or credit depletion.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
