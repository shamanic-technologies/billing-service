{
  "openapi": "3.0.0",
  "info": {
    "title": "Billing Service API",
    "version": "0.1.0",
    "description": "Manages billing accounts, credit balance, deductions, and Stripe integration for the Conductor platform."
  },
  "servers": [
    {
      "url": "http://localhost:3012"
    }
  ],
  "components": {
    "schemas": {
      "BillingGrowthRow": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string"
          },
          "credited_cents": {
            "type": "string"
          },
          "revenue_cents": {
            "type": "string"
          }
        },
        "required": [
          "period",
          "credited_cents",
          "revenue_cents"
        ]
      },
      "PublicBillingStats": {
        "type": "object",
        "properties": {
          "totalAccounts": {
            "type": "integer"
          },
          "accountsWithPaymentMethod": {
            "type": "integer"
          },
          "totalGrantsCents": {
            "type": "string"
          },
          "totalCreditedCents": {
            "type": "string"
          },
          "monthlyGrowth": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillingGrowthRow"
            }
          },
          "weeklyGrowth": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BillingGrowthRow"
            }
          }
        },
        "required": [
          "totalAccounts",
          "accountsWithPaymentMethod",
          "totalGrantsCents",
          "totalCreditedCents",
          "monthlyGrowth",
          "weeklyGrowth"
        ]
      },
      "BillingAccount": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "orgId": {
            "type": "string",
            "format": "uuid"
          },
          "grantsCents": {
            "type": "string"
          },
          "runsSpentCents": {
            "type": "string"
          },
          "availableCents": {
            "type": "string"
          },
          "reloadAmountCents": {
            "type": "integer",
            "nullable": true
          },
          "reloadThresholdCents": {
            "type": "integer",
            "nullable": true
          },
          "hasPaymentMethod": {
            "type": "boolean"
          },
          "hasAutoReload": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "orgId",
          "grantsCents",
          "runsSpentCents",
          "availableCents",
          "reloadAmountCents",
          "reloadThresholdCents",
          "hasPaymentMethod",
          "hasAutoReload",
          "createdAt",
          "updatedAt"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "BalanceResponse": {
        "type": "object",
        "properties": {
          "balance_cents": {
            "type": "string"
          },
          "depleted": {
            "type": "boolean"
          }
        },
        "required": [
          "balance_cents",
          "depleted"
        ]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "amount_cents": {
            "type": "integer"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "credit",
              "reload"
            ]
          }
        },
        "required": [
          "id",
          "amount_cents",
          "description",
          "created_at",
          "type"
        ]
      },
      "TransactionsResponse": {
        "type": "object",
        "properties": {
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "has_more": {
            "type": "boolean"
          }
        },
        "required": [
          "transactions",
          "has_more"
        ]
      },
      "UpdateAutoReloadRequest": {
        "type": "object",
        "properties": {
          "reload_amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "reload_threshold_cents": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "reload_amount_cents"
        ]
      },
      "PortalSessionResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      },
      "CreatePortalSessionRequest": {
        "type": "object",
        "properties": {
          "return_url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "return_url"
        ]
      },
      "CheckoutResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "session_id"
        ]
      },
      "CreateCheckoutRequest": {
        "type": "object",
        "properties": {
          "success_url": {
            "type": "string",
            "format": "uri"
          },
          "cancel_url": {
            "type": "string",
            "format": "uri"
          },
          "reload_amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          }
        },
        "required": [
          "success_url",
          "cancel_url",
          "reload_amount_cents"
        ]
      },
      "AuthorizeResponse": {
        "type": "object",
        "properties": {
          "sufficient": {
            "type": "boolean"
          },
          "balance_cents": {
            "type": "string"
          },
          "required_cents": {
            "type": "string"
          }
        },
        "required": [
          "sufficient",
          "balance_cents",
          "required_cents"
        ]
      },
      "AuthorizeCostItem": {
        "type": "object",
        "properties": {
          "costName": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          }
        },
        "required": [
          "costName",
          "quantity"
        ]
      },
      "AuthorizeRequest": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorizeCostItem"
            },
            "minItems": 1
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "items"
        ]
      },
      "UsageNotifyResponse": {
        "type": "object",
        "properties": {
          "acknowledged": {
            "type": "boolean"
          },
          "reload_triggered": {
            "type": "boolean"
          }
        },
        "required": [
          "acknowledged",
          "reload_triggered"
        ]
      },
      "UsageNotifyRequest": {
        "type": "object",
        "properties": {
          "spent_total_cents": {
            "type": "string"
          }
        },
        "required": [
          "spent_total_cents"
        ]
      },
      "RedeemPromoResponse": {
        "type": "object",
        "properties": {
          "redeemed": {
            "type": "boolean"
          },
          "amount_cents": {
            "type": "integer"
          },
          "balance_cents": {
            "type": "string"
          }
        },
        "required": [
          "redeemed",
          "amount_cents",
          "balance_cents"
        ]
      },
      "RedeemPromoRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "code"
        ]
      },
      "TransferBrandTableResult": {
        "type": "object",
        "properties": {
          "tableName": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        },
        "required": [
          "tableName",
          "count"
        ]
      },
      "TransferBrandResponse": {
        "type": "object",
        "properties": {
          "updatedTables": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransferBrandTableResult"
            }
          }
        },
        "required": [
          "updatedTables"
        ]
      },
      "TransferBrandRequest": {
        "type": "object",
        "properties": {
          "sourceBrandId": {
            "type": "string",
            "format": "uuid"
          },
          "sourceOrgId": {
            "type": "string",
            "format": "uuid"
          },
          "targetOrgId": {
            "type": "string",
            "format": "uuid"
          },
          "targetBrandId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "sourceBrandId",
          "sourceOrgId",
          "targetOrgId"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "service": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "service"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/public/stats/billing": {
      "get": {
        "summary": "Aggregate billing stats (no auth)",
        "description": "Cross-tenant aggregate billing statistics. No authentication required.",
        "responses": {
          "200": {
            "description": "Billing stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicBillingStats"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts": {
      "get": {
        "summary": "Get or create billing account for org",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Billing account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingAccount"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Payment provider authentication failed (e.g. expired Stripe key)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts/balance": {
      "get": {
        "summary": "Quick balance check from DB cache",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Balance info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts/transactions": {
      "get": {
        "summary": "Get credit transaction history from Stripe",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionsResponse"
                }
              }
            }
          },
          "502": {
            "description": "Payment provider authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/accounts/auto-reload": {
      "patch": {
        "summary": "Configure auto-reload settings (requires payment method)",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAutoReloadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingAccount"
                }
              }
            }
          },
          "400": {
            "description": "Payment method required or invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Billing account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Disable auto-reload",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Workflow slug injected by workflow-service"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Feature slug for tracking"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated account with auto-reload disabled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingAccount"
                }
              }
            }
          },
          "404": {
            "description": "Billing account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/portal-sessions": {
      "post": {
        "summary": "Create Stripe Customer Portal session for payment method management",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Campaign ID injected by workflow-service"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "description": "Brand ID(s) injected by workflow-service (comma-separated UUIDs for multi-brand campaigns)",
              "example": "uuid1,uuid2,uuid3"
            },
            "required": false,
            "name": "x-brand-id",
